{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["RTK.md"],
  "agent": {
    "build": { "steps": 30 },
    "general": { "steps": 20 },
  },
  "default_agent": "plan",
  "lsp": {
    "helm-ls": {
      "command": ["helm_ls", "serve"],
      "extensions": [".tpl"],
    },
  },
  "mcp": {
    "argocd": {
      "type": "local",
      "command": ["npx", "-y", "argocd-mcp@latest", "stdio"],
      "environment": {
        "ARGOCD_BASE_URL": "$ARGOCD_BASE_URL",
        "ARGOCD_API_TOKEN": "$ARGOCD_API_TOKEN",
        "MCP_READ_ONLY": "true",
      },
    },
    "atlassian": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/sse",
    },
    "aws-knowledge": {
      "type": "remote",
      "url": "https://knowledge-mcp.global.api.aws",
    },
    "brew": {
      "type": "local",
      "command": ["brew", "mcp-server"],
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
    },
    "github": {
      "type": "local",
      "command": [
        "sh",
        "-c",
        "GITHUB_PERSONAL_ACCESS_TOKEN=$(gh auth token) github-mcp-server stdio",
      ],
    },
    "icm": {
      "type": "local",
      "command": ["icm", "serve", "--compact"],
    },
    "kubernetes": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "kubernetes-mcp-server@latest",
        "--read-only",
        "--toolsets",
        "core,config,helm",
      ],
    },
    "mise": {
      "type": "local",
      "command": ["mise", "mcp"],
      "environment": { "MISE_EXPERIMENTAL": "1" },
    },
    "nix": {
      "type": "local",
      "command": ["uvx", "--python", "3.13", "mcp-nix"],
    },
    "spacelift": {
      "type": "local",
      "command": ["spacectl", "mcp", "server"],
    },
    "terraform": {
      "type": "local",
      "command": ["terraform-mcp-server"],
    },
  },
  "permission": {
    "read": {
      "**/*.pem": "deny",
      "**/*.key": "deny",
      "**/credentials.json": "deny",
      "**/secrets.*": "deny",
    },
    "websearch": "allow",
  },
  "plugin": ["@tarquinen/opencode-dcp@latest"],
  "provider": {
    "anthropic": {
      "options": { "setCacheKey": true },
    },
  },
}
