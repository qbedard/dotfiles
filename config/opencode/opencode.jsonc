{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": { "steps": 30 },
    "general": { "steps": 20 }
  },
  "mcp": {
    "atlassian": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/sse"
    },
    "aws-knowledge": {
      "type": "remote",
      "url": "https://knowledge-mcp.global.api.aws"
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    }
  },
  "permission": {
    "websearch": "allow"
  },
  "provider": {
    "anthropic": {
      "options": { "setCacheKey": true }
    }
  }
}
